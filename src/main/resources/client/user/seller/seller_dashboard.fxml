<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="650.0" prefWidth="1050.0" style="-fx-background-color: #eef3f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.SellerDashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="66.0" style="-fx-background-color: white; -fx-border-color: #dbe3ee; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <children>
                <Label text="AUCTION SYSTEM" textFill="#111827">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                    <HBox.margin>
                        <Insets left="28.0" />
                    </HBox.margin>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblWelcome" text="Xin chào, Seller" textFill="#475569">
                    <font>
                        <Font size="14.0" />
                    </font>
                    <HBox.margin>
                        <Insets right="18.0" />
                    </HBox.margin>
                </Label>
                <Button mnemonicParsing="false" onAction="#onLogoutButtonClicked" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6;" text="Đăng xuất">
                    <padding>
                        <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
                    </padding>
                    <HBox.margin>
                        <Insets right="26.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="300.0" spacing="14.0" style="-fx-background-color: #111c31;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="28.0" right="28.0" top="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="16.0">
                    <children>
                        <StackPane minHeight="58.0" minWidth="58.0" prefHeight="58.0" prefWidth="58.0">
                            <children>
                                <Circle fill="#f4c96b" radius="29.0" />
                                <Label text="♟" textFill="#111c31">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </StackPane>
                        <VBox spacing="3.0">
                            <children>
                                <Label fx:id="lblSellerName" text="Hòa Nguyễn" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblSellerRole" text="Chủ Kênh" textFill="#aab4c5">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Label text="KÊNH NGƯỜI BÁN ⚒" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <VBox spacing="4.0">
                    <children>
                        <Button fx:id="btnProducts" maxWidth="Infinity" mnemonicParsing="false" onAction="#onManageAuctionsClicked" prefHeight="44.0" style="-fx-background-color: #243149; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-background-radius: 7; -fx-border-color: #13d6a3; -fx-border-width: 0 0 0 4; -fx-border-radius: 7;" text="▣  Sản phẩm của tôi">
                            <font>
                                <Font size="14.0" />
                            </font>
                            <padding>
                                <Insets left="18.0" right="12.0" />
                            </padding>
                        </Button>
                        <Button fx:id="btnOrders" maxWidth="Infinity" mnemonicParsing="false" onAction="#onManageOrdersClicked" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="▤  Quản lý Đơn hàng">
                            <font>
                                <Font size="14.0" />
                            </font>
                            <padding>
                                <Insets left="18.0" right="12.0" />
                            </padding>
                        </Button>
                        <Button fx:id="btnRevenue" maxWidth="Infinity" mnemonicParsing="false" onAction="#onRevenueStatisticsClicked" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="▥  Thống kê doanh thu">
                            <font>
                                <Font size="14.0" />
                            </font>
                            <padding>
                                <Insets left="18.0" right="12.0" />
                            </padding>
                        </Button>
                        <Button fx:id="btnWallet" maxWidth="Infinity" mnemonicParsing="false" onAction="#onWalletButtonClicked" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="Ví tiền">
                            <font>
                                <Font size="14.0" />
                            </font>
                            <padding>
                                <Insets left="18.0" right="12.0" />
                            </padding>
                        </Button>
                        <StackPane alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnNotifications" maxWidth="Infinity" mnemonicParsing="false" onAction="#onNotificationsClicked" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="Thông báo">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                    <padding>
                                        <Insets left="18.0" right="12.0" />
                                    </padding>
                                </Button>
                                <Label fx:id="lblNotificationBadge" alignment="CENTER" managed="false" minHeight="22.0" minWidth="22.0" mouseTransparent="true" style="-fx-background-color: #ef4444; -fx-background-radius: 11; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: white;" text="0" visible="false">
                                    <StackPane.margin>
                                        <Insets right="14.0" />
                                    </StackPane.margin>
                                </Label>
                            </children>
                        </StackPane>
                    </children>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <VBox spacing="4.0">
                    <children>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onBuyerChannelClicked" prefHeight="45.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-background-radius: 5;" text="Kênh Người Mua">
                            <font>
                                <Font size="14.0" />
                            </font>
                            <padding>
                                <Insets left="18.0" right="12.0" />
                            </padding>
                        </Button>
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenSettings" prefHeight="42.0" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="Cài đặt">
                            <font>
                                <Font size="14.0" />
                            </font>
                            <padding>
                                <Insets left="18.0" right="12.0" />
                            </padding>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="ALWAYS" pannable="true" vbarPolicy="ALWAYS" style="-fx-background-color: #eef3f8;" BorderPane.alignment="CENTER">
            <content>
                <StackPane fx:id="contentArea" style="-fx-background-color: #eef3f8;" />
            </content>
        </ScrollPane>
    </center>
</BorderPane>
