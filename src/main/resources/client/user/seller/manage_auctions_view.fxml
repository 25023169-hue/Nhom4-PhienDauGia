<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="18.0" style="-fx-background-color: #eef3f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.SellerProductListController">
    <padding>
        <Insets bottom="30.0" left="34.0" right="34.0" top="30.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Sản phẩm của tôi">
                    <font>
                        <Font name="System Bold" size="30.0" />
                    </font>
                </Label>
                <Label text="🎁">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
                <Label fx:id="lblCount" text="(0 items)" textFill="#64748b">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#onAddProductClicked" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 7;" text="Add Product +">
                    <padding>
                        <Insets bottom="11.0" left="26.0" right="26.0" top="11.0" />
                    </padding>
                </Button>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <children>
                <TextField fx:id="txtSearch" prefHeight="42.0" promptText="🔍 Nhập tên hoặc ID sản phẩm..." style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #d7dee8; -fx-border-radius: 8; -fx-padding: 0 14;" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <HBox spacing="12.0">
            <children>
                <Button fx:id="btnOpenStatus" mnemonicParsing="false" text="OPEN: 0" />
                <Button fx:id="btnRunningStatus" mnemonicParsing="false" text="RUNNING: 0" />
                <Button fx:id="btnFinishedStatus" mnemonicParsing="false" text="FINISHED: 0" />
                <Button fx:id="btnCancelledStatus" mnemonicParsing="false" text="CANCELLED: 0" />
            </children>
        </HBox>

        <TableView fx:id="tableProducts" prefHeight="430.0" style="-fx-background-color: white; -fx-border-color: #f0c66d; -fx-border-width: 5 0 0 0;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colItemId" prefWidth="80.0" text="ID" />
                <TableColumn fx:id="colItemName" prefWidth="340.0" text="Tên Sản Phẩm" />
                <TableColumn fx:id="colStartingPrice" prefWidth="180.0" text="Giá Khởi Điểm" />
                <TableColumn fx:id="colStatus" prefWidth="150.0" text="Trạng Thái" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</VBox>
