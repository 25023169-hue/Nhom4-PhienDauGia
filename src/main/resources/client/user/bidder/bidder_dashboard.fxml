<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.BidderDashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #2c3e50; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);" BorderPane.alignment="CENTER">
            <children>
                <Label onMouseClicked="#onHomeButtonClicked" style="-fx-cursor: hand;" text="AUCTION SYSTEM" textFill="WHITE">
                    <font><Font name="System Bold" size="22.0" /></font>
                    <HBox.margin><Insets left="25.0" /></HBox.margin>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblWelcome" text="Xin chào, Guest" textFill="WHITE">
                    <font><Font size="15.0" /></font>
                    <HBox.margin><Insets right="20.0" /></HBox.margin>
                </Label>
                <Button mnemonicParsing="false" onAction="#onLogoutButtonClicked" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Đăng xuất">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                    <HBox.margin><Insets right="25.0" /></HBox.margin>
                </Button>
            </children>
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebar" prefWidth="220.0" minWidth="220.0" maxWidth="220.0" spacing="10.0" style="-fx-background-color: #34495e;" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnHome" maxWidth="Infinity" mnemonicParsing="false" onAction="#onHomeButtonClicked" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="⌂ Trang chủ">
                    <font><Font name="System Bold" size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>
                <Button fx:id="btnProductList" maxWidth="Infinity" mnemonicParsing="false" onAction="#onProductListButtonClicked" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="📦 Danh sách sản phẩm">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onLiveBidsClicked" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="🔨 Đang tham gia">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onPurchaseHistoryClicked" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="📜 Lịch sử mua hàng">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onInventoryClicked" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="▣ Sản phẩm đã thắng">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>

                <Button fx:id="btnWallet" maxWidth="Infinity" mnemonicParsing="false" onAction="#onWalletButtonClicked" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="👤 Ví tiền">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onNotificationsClicked" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="🔔 Thông báo">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onSellerChannelButtonClicked" prefHeight="45.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-background-radius: 5;" text="🏪 Kênh Người Bán">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                    <VBox.margin><Insets bottom="5.0" left="10.0" right="10.0" /></VBox.margin>
                </Button>
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenSettings" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="⚙ Cài đặt">
                    <font><Font size="14.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Button>
            </children>
            <padding><Insets bottom="15.0" top="20.0" /></padding>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="ALWAYS" pannable="true" vbarPolicy="ALWAYS" style="-fx-background-color: #f4f7f6;" BorderPane.alignment="CENTER">
            <content>
                <StackPane fx:id="contentArea" style="-fx-background-color: #f4f7f6;" />
            </content>
        </ScrollPane>
    </center>
</BorderPane>
