<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="620.0" prefWidth="1000.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.SellerRegistrationController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="58.0" spacing="8.0" style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="18.0" right="18.0" />
            </padding>
            <children>
                <Label text="Auction System" textFill="#f04b2f">
                    <font>
                        <Font name="System Bold" size="19.0" />
                    </font>
                </Label>
                <Label text="Đăng ký trở thành Người bán" textFill="#333333">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#onCancelButtonClicked" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-cursor: hand;" text="Quay lại" />
            </children>
        </HBox>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets bottom="48.0" left="70.0" right="70.0" top="24.0" />
            </padding>
            <children>
                <VBox fx:id="introPane" alignment="CENTER" maxWidth="780.0" minHeight="430.0" spacing="22.0" style="-fx-background-color: white; -fx-background-radius: 4; -fx-border-color: #e7e7e7; -fx-border-radius: 4; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.10), 8, 0, 0, 2);">
                    <padding>
                        <Insets bottom="44.0" left="44.0" right="44.0" top="44.0" />
                    </padding>
                    <children>
                        <StackPane prefHeight="150.0" prefWidth="170.0">
                            <children>
                                <Circle fill="#fff0eb" radius="82.0" />
                                <Rectangle arcHeight="8.0" arcWidth="8.0" fill="#ffffff" height="72.0" stroke="#ffd6cc" width="130.0" />
                                <Rectangle arcHeight="6.0" arcWidth="6.0" fill="#f04b2f" height="30.0" translateX="-24.0" translateY="-16.0" width="92.0" />
                                <Rectangle arcHeight="4.0" arcWidth="4.0" fill="#ffb7a9" height="12.0" translateX="46.0" translateY="-38.0" width="62.0" />
                                <Rectangle fill="#ffd8cf" height="5.0" translateY="18.0" width="76.0" />
                                <Rectangle fill="#ffd8cf" height="5.0" translateY="34.0" width="58.0" />
                            </children>
                        </StackPane>

                        <Label text="Chào mừng đến với Auction System!" textFill="#222222">
                            <font>
                                <Font size="22.0" />
                            </font>
                        </Label>

                        <Label alignment="CENTER" maxWidth="360.0" text="Vui lòng cung cấp thông tin để thiết lập tài khoản người bán trên Auction System" textAlignment="CENTER" textFill="#555555" wrapText="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>

                        <Button mnemonicParsing="false" onAction="#onStartRegistrationButtonClicked" style="-fx-background-color: #f04b2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" text="Bắt đầu đăng ký">
                            <padding>
                                <Insets bottom="10.0" left="22.0" right="22.0" top="10.0" />
                            </padding>
                        </Button>
                    </children>
                </VBox>

                <VBox fx:id="formPane" alignment="CENTER" managed="false" maxWidth="520.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-border-color: #e7e7e7; -fx-background-radius: 8; -fx-border-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.10), 8, 0, 0, 2);" visible="false">
                    <padding>
                        <Insets bottom="34.0" left="42.0" right="42.0" top="34.0" />
                    </padding>
                    <children>
                        <Label text="ĐĂNG KÝ KÊNH NGƯỜI BÁN" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>

                        <Label text="Vui lòng nhập tên Shop/Cửa hàng của bạn để bắt đầu bán các vật phẩm đấu giá:" textAlignment="CENTER" textFill="#7f8c8d" wrapText="true" />

                        <TextField fx:id="txtStoreName" prefHeight="40.0" promptText="Ví dụ: Shop Đồ Cổ Tuấn Vũ..." style="-fx-font-size: 14px;">
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </TextField>

                        <Label fx:id="lblError" alignment="CENTER" managed="false" maxWidth="1.7976931348623157E308" text="Thông báo" textAlignment="CENTER" visible="false">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>

                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#onCancelButtonClicked" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Hủy bỏ" />
                                <Button mnemonicParsing="false" onAction="#onConfirmButtonClicked" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Xác nhận đăng ký" />
                            </children>
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
