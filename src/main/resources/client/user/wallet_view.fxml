<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.Separator?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.WalletController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="Giao dịch &amp; Ví tiền"><font><Font name="System Bold" size="24.0" /></font></Label>
                        <Label text="Quản lý số dư, nạp rút tiền và lịch sử dòng tiền thực tế." textFill="#6b7c85" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="4.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 16;">
                    <children>
                        <Label text="Số dư khả dụng" textFill="#7f8c8d" />
                        <Label fx:id="lblBalance" text="0 ₫" textFill="#1abc9c">
                            <font><Font name="System Bold" size="26.0" /></font>
                        </Label>
                        <Label fx:id="lblTotalBalance" text="Tổng số dư: 0 ₫" textFill="#7f8c8d" />
                        <Label fx:id="lblHeldBalance" text="Đang giữ đấu giá: 0 ₫" textFill="#e67e22" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="12.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 20;">
            <children>
                <HBox spacing="12.0">
                    <children>
                        <TextField fx:id="txtAmount" prefWidth="220.0" promptText="Số tiền" />
                        <TextField fx:id="txtNote" HBox.hgrow="ALWAYS" promptText="Ghi chú" />
                        <Button mnemonicParsing="false" onAction="#onDepositButtonClicked" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Nạp tiền">
                            <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#onWithdrawButtonClicked" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Rút tiền">
                            <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                        </Button>
                    </children>
                </HBox>
                <HBox fx:id="bankErrorBox" alignment="CENTER_LEFT" managed="false" spacing="8.0" visible="false">
                    <children>
                        <Label fx:id="lblTransactionError" textFill="#e74c3c" />
                        <Button fx:id="btnSetupBank" mnemonicParsing="false" onAction="#onOpenBankSettings" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;" text="Thiết lập ngân hàng" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #e6ecf0; -fx-border-radius: 6;">
            <children>
                <TextField fx:id="txtSearch" prefWidth="220.0" promptText="🔍 Tìm theo ghi chú..." style="-fx-background-radius: 4;" />
                <ComboBox fx:id="cbTimeFilter" prefWidth="130.0" promptText="Thời gian" style="-fx-background-radius: 4; -fx-cursor: hand;" />
                <Separator orientation="VERTICAL" />
                <Button fx:id="btnFilterIn" mnemonicParsing="false" onAction="#onFilterInClicked" style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-text-fill: #7f8c8d; -fx-cursor: hand; -fx-font-weight: bold;" text="⬇ Tiền vào" />
                <Button fx:id="btnFilterOut" mnemonicParsing="false" onAction="#onFilterOutClicked" style="-fx-background-color: transparent; -fx-border-color: #bdc3c7; -fx-border-radius: 4; -fx-text-fill: #7f8c8d; -fx-cursor: hand; -fx-font-weight: bold;" text="⬆ Tiền ra" />
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#onClearFilterClicked" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Xóa bộ lọc" />
            </children>
        </HBox>

        <TableView fx:id="tableWalletHistory" prefHeight="260.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTransactionId" prefWidth="70.0" text="ID" />
                <TableColumn fx:id="colTransactionTime" prefWidth="160.0" text="Thời gian" />
                <TableColumn fx:id="colMoneyIn" prefWidth="130.0" text="Tiền vào (+)" />
                <TableColumn fx:id="colMoneyOut" prefWidth="130.0" text="Tiền ra (-)" />
                <TableColumn fx:id="colLastBalance" prefWidth="140.0" text="Số dư sau" />
                <TableColumn fx:id="colTransactionType" prefWidth="100.0" text="Phân loại" />
                <TableColumn fx:id="colTransactionNote" prefWidth="240.0" text="Ghi chú" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</VBox>
