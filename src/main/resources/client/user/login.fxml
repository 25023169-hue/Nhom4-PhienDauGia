<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane
        style="-fx-background-color: linear-gradient(to bottom right, #eef2f3, #dfe9f3);"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="client.controller.LoginController">

    <children>

        <VBox
                alignment="CENTER"
                prefHeight="1280.0"
                prefWidth="720.0"
                spacing="15.0"

                AnchorPane.topAnchor="0.0"
                AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0"

                style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-padding: 20;
                     -fx-max-width: 350;
                     -fx-max-height: 500;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 8);">

            <children>

                <Label text="Đăng Nhập">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>

                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>

                <VBox spacing="5.0" style="-fx-spacing: 5;">

                    <children>

                        <Label
                                style="-fx-text-fill: #555; -fx-font-size: 13px;"
                                text="Tên đăng nhập:" />

                        <TextField
                                fx:id="txtUsername"
                                prefHeight="35.0"
                                promptText="Nhập tên đăng nhập..."
                                style="-fx-background-radius: 10;
                                     -fx-border-radius: 10;
                                     -fx-border-color: #ddd;
                                     -fx-padding: 10;
                                     -fx-background-color: #fafafa;" />

                        <Label
                                fx:id="lblUserError"
                                managed="false"
                                style="-fx-text-fill: red; -fx-font-size: 11px;"
                                text="Vui lòng nhập tên đăng nhập"
                                textFill="RED"
                                visible="false">

                            <font>
                                <Font size="11.0" />
                            </font>

                        </Label>

                    </children>

                    <VBox.margin>
                        <Insets left="40.0" right="40.0" />
                    </VBox.margin>

                </VBox>

                <VBox spacing="5.0" style="-fx-spacing: 5;">

                    <children>

                        <Label
                                style="-fx-text-fill: #555; -fx-font-size: 13px;"
                                text="Mật khẩu:" />

                        <PasswordField
                                fx:id="txtPassword"
                                prefHeight="35.0"
                                promptText="Nhập mật khẩu..."
                                style="-fx-background-radius: 10;
                                     -fx-border-radius: 10;
                                     -fx-border-color: #ddd;
                                     -fx-padding: 10;
                                     -fx-background-color: #fafafa;" />

                        <Label
                                fx:id="lblPassError"
                                managed="false"
                                style="-fx-text-fill: red; -fx-font-size: 11px;"
                                text="Vui lòng nhập mật khẩu"
                                textFill="RED"
                                visible="false">

                            <font>
                                <Font size="11.0" />
                            </font>

                        </Label>

                    </children>

                    <VBox.margin>
                        <Insets left="40.0" right="40.0" />
                    </VBox.margin>

                </VBox>

                <Label
                        fx:id="lblGeneralError"
                        managed="false"
                        style="-fx-font-size: 10;"
                        text="Lỗi đăng nhập"
                        textFill="RED"
                        visible="false">

                    <font>
                        <Font name="System Italic" size="12.0" />
                    </font>

                </Label>

                <Button
                        mnemonicParsing="false"
                        onAction="#onLoginButtonClicked"
                        prefHeight="40.0"
                        prefWidth="270.0"

                        style="-fx-background-color: #2196F3;
                             -fx-text-fill: white;
                             -fx-font-weight: bold;
                             -fx-cursor: hand;
                             -fx-background-radius: 15;
                             -fx-background-color: linear-gradient(to right, #36d1dc, #5b86e5);
                             -fx-text-fill: white;
                             -fx-font-size: 15px;
                             -fx-font-weight: bold;
                             -fx-padding: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10, 0, 0, 4);"

                        text="Đăng Nhập">

                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>

                </Button>

                <Button
                        mnemonicParsing="false"
                        onAction="#onRegisterLinkClick"

                        style="-fx-background-color: transparent;
                             -fx-text-fill: #2196F3;
                             -fx-cursor: hand;
                             -fx-underline: true;"

                        text="Chưa có tài khoản? Đăng ký ngay" />

            </children>

        </VBox>

    </children>

</AnchorPane>