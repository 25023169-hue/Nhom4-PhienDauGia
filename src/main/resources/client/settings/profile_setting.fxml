<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.ProfileSettingController">
    <Label text="Thông tin cá nhân"><font><Font name="System Bold" size="22"/></font></Label>
    <GridPane hgap="10" vgap="15">
        <Label text="Tên đăng nhập:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtUsername" disable="true" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Label text="Họ:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtLastName" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label text="Tên:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="txtFirstName" GridPane.columnIndex="1" GridPane.rowIndex="2" />
    </GridPane>
    <Button onAction="#saveProfile" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Lưu thay đổi" />
    <Region VBox.vgrow="ALWAYS" />
    <Separator />
    <Button fx:id="btnDeleteAccount" onAction="#deleteAccount" style="-fx-text-fill: #e74c3c; -fx-background-color: transparent; -fx-border-color: #e74c3c; -fx-border-radius: 4;" text="Xóa tài khoản vĩnh viễn" />
</VBox>
