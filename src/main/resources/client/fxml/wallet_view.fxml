<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.WalletController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="Ví tiền"><font><Font name="System Bold" size="24.0" /></font></Label>
                        <Label text="Quản lý số dư, nạp rút tiền và lịch sử giao dịch." textFill="#6b7c85" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="4.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 16;">
                    <children>
                        <Label text="Số dư hiện có" textFill="#7f8c8d" />
                        <Label fx:id="lblWalletBalance" text="0 ₫" textFill="#1abc9c">
                            <font><Font name="System Bold" size="26.0" /></font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
        <VBox spacing="12.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 20;">
            <children>
                <HBox spacing="12.0">
                    <children>
                        <TextField fx:id="txtWalletAmount" prefWidth="220.0" promptText="Số tiền" />
                        <TextField fx:id="txtWalletNote" HBox.hgrow="ALWAYS" promptText="Ghi chú" />
                        <Button mnemonicParsing="false" onAction="#onDepositButtonClicked" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Nạp tiền">
                            <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#onWithdrawButtonClicked" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Rút tiền">
                            <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                        </Button>
                    </children>
                </HBox>
                <HBox fx:id="walletBankErrorBox" alignment="CENTER_LEFT" managed="false" spacing="8.0" visible="false">
                    <children>
                        <Label fx:id="lblWalletError" textFill="#e74c3c" />
                        <Button fx:id="btnSetupBank" mnemonicParsing="false" onAction="#onOpenBankSettings" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;" text="Thiết lập ngân hàng" />
                    </children>
                </HBox>
            </children>
        </VBox>
        <TableView fx:id="tableWalletHistory" prefHeight="260.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colWalletTime" prefWidth="190.0" text="Thời gian" />
                <TableColumn fx:id="colWalletAmount" prefWidth="150.0" text="Số tiền" />
                <TableColumn fx:id="colLastBalance" prefWidth="150.0" text=" Số dư sau" />
                <TableColumn fx:id="colWalletType" prefWidth="120.0" text="Phân loại" />
                <TableColumn fx:id="colWalletNote" prefWidth="260.0" text="Ghi chú" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</VBox>