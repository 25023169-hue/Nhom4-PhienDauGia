<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.SellerDashboardController">

    <left>
        <VBox prefWidth="220.0" spacing="15.0" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            <children>
                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="KÊNH NGƯỜI BÁN" textFill="#ecf0f1" wrapText="true">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>

                <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="📦 Sản phẩm của tôi">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font></Button>
                <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: center-left;" text="🛒 Quản lý Đơn hàng" />
                <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: center-left;" text="📊 Thống kê doanh thu" />

                <Region VBox.vgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#onBackToBuyerChannelClicked" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="⬅ Trở về Kênh Người Mua" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: #f4f6f7;">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="Sản phẩm của tôi">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button mnemonicParsing="false" onAction="#onAddProductClicked" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Thêm sản phẩm mới" />
                    </children>
                </HBox>

                <TableView fx:id="tableMyProducts" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colName" prefWidth="250.0" text="Tên Sản Phẩm" />
                        <TableColumn fx:id="colPrice" prefWidth="130.0" text="Giá Khởi Điểm" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Trạng Thái" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>