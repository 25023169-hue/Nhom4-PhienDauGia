<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.PasswordSettingController">
    <Label text="Thay đổi mật khẩu"><font><Font name="System Bold" size="22"/></font></Label>
    <VBox spacing="15" maxWidth="400">
        <PasswordField fx:id="txtOldPass" prefHeight="40" promptText="Mật khẩu hiện tại" />
        <PasswordField fx:id="txtNewPass" prefHeight="40" promptText="Mật khẩu mới" />
        <TextField fx:id="txtRecovery" prefHeight="40" promptText="Nhập mã Recovery Code" />
    </VBox>
    <Button onAction="#savePassword" prefHeight="40" prefWidth="150" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Xác nhận đổi" />
</VBox>