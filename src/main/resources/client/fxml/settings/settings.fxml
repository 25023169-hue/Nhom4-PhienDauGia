<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.SettingsController">
    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            <children>
                <Label text="THIẾT LẬP" textFill="#95a5a6">
                    <font><Font name="System Bold" size="12.0" /></font>
                    <VBox.margin><Insets bottom="10"/></VBox.margin>
                </Label>

                <Button fx:id="btnProfile" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#showProfile" style="-fx-background-color: transparent; -fx-cursor: hand;" text="👤 Hồ sơ cá nhân" />
                <Button fx:id="btnBank" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#showBank" style="-fx-background-color: transparent; -fx-cursor: hand;" text="🏦 Ngân hàng" />
                <Button fx:id="btnAddress" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#showAddress" style="-fx-background-color: transparent; -fx-cursor: hand;" text="📍 Địa chỉ" />
                <Button fx:id="btnPassword" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#showPassword" style="-fx-background-color: transparent; -fx-cursor: hand;" text="🔑 Đổi mật khẩu" />

                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#onBack" style="-fx-background-color: transparent; -fx-cursor: hand;" text="← Quay lại" />
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: white;">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
        </StackPane>
    </center>
</BorderPane>