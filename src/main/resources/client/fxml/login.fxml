<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="350.0" spacing="15.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="io.auctionsystem.client.controller.LoginController">

    <children>
        <Label text="Đăng Nhập">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
            <VBox.margin>
                <Insets bottom="20.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="5.0">
            <children>
                <Label text="Tên đăng nhập:" />
                <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập..." prefHeight="35.0" />
                <Label fx:id="lblUserError" text="Vui lòng nhập tên đăng nhập" textFill="RED" visible="false" managed="false">
                    <font><Font size="11.0" /></font>
                </Label>
            </children>
            <VBox.margin>
                <Insets left="40.0" right="40.0" />
            </VBox.margin>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Mật khẩu:" />
                <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu..." prefHeight="35.0" />
                <Label fx:id="lblPassError" text="Vui lòng nhập mật khẩu" textFill="RED" visible="false" managed="false">
                    <font><Font size="11.0" /></font>
                </Label>
            </children>
            <VBox.margin>
                <Insets left="40.0" right="40.0" />
            </VBox.margin>
        </VBox>

        <Label fx:id="lblGeneralError" text="Lỗi đăng nhập" textFill="RED" visible="false" managed="false">
            <font><Font name="System Italic" size="12.0" /></font>
        </Label>

        <Button mnemonicParsing="false" onAction="#onLoginButtonClicked" prefHeight="40.0" prefWidth="270.0" text="Đăng Nhập" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>

        <Button mnemonicParsing="false" onAction="#onRegisterLinkClick" text="Chưa có tài khoản? Đăng ký ngay" style="-fx-background-color: transparent; -fx-text-fill: #2196F3; -fx-cursor: hand;" />
    </children>
</VBox>