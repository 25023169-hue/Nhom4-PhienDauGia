<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.InventoryController" spacing="10">
    <Label text="Túi đồ của bạn (Các phiên đã thắng)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>

    <TableView fx:id="tableInventory" VBox.vgrow="ALWAYS" prefHeight="250">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70" />
            <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="300" />
            <TableColumn fx:id="colFinalPrice" text="Giá chiến thắng" prefWidth="150" />
            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>
