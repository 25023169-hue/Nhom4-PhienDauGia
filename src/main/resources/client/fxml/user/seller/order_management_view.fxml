<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootPane" alignment="CENTER" prefHeight="650.0" prefWidth="900.0" spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.SellerOrderManagementController">
    <Label text="Quản Lý Đơn Hàng Đang Chạy">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label style="-fx-text-fill: #64748b;" text="Chọn một sản phẩm để theo dõi biểu đồ giá theo thời gian thực." />

    <TableView fx:id="tableOrders" prefHeight="190.0" prefWidth="850.0">
        <columns>
            <TableColumn fx:id="colProductName" prefWidth="390.0" text="Sản phẩm" />
            <TableColumn fx:id="colCurrentPrice" prefWidth="200.0" text="Giá hiện tại" />
            <TableColumn fx:id="colEndTime" prefWidth="240.0" text="Kết thúc" />
        </columns>
    </TableView>

    <Label fx:id="lblEmptyState" style="-fx-text-fill: #64748b; -fx-font-style: italic;" text="Bạn chưa có sản phẩm nào đang đấu giá." />

    <VBox fx:id="detailPane" alignment="CENTER" managed="false" spacing="12.0" visible="false">
        <Label fx:id="lblProductName" style="-fx-font-size: 16px; -fx-text-fill: #34495e;" text="Sản phẩm đang tải..." />
        <Label fx:id="lblCurrentPrice" style="-fx-font-size: 24px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;" text="0 ₫" />
        <Label fx:id="lblTimeRemaining" style="-fx-font-size: 15px; -fx-text-fill: #d35400; -fx-font-weight: bold;" text="Thời gian còn lại: --:--:--" />
        <Button onAction="#onDeleteAuctionClicked" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 18;" text="Xóa phiên" />

        <LineChart fx:id="priceChart" animated="false" prefHeight="320.0" prefWidth="850.0" title="Đồ thị diễn biến giá đấu">
            <xAxis>
                <CategoryAxis label="Thời gian" side="BOTTOM" />
            </xAxis>
            <yAxis>
                <NumberAxis label="Mức giá (VNĐ)" side="LEFT" />
            </yAxis>
        </LineChart>
    </VBox>
</VBox>
