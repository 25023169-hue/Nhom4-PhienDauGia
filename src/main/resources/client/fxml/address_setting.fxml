<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.AddressSettingController">
    <children>
        <Label text="Địa chỉ nhận hàng"><font><Font name="System Bold" size="22"/></font></Label>
        <VBox spacing="8.0">
            <children>
                <Label text="Chuỗi địa chỉ chi tiết của bạn:" textFill="#7f8c8d"><font><Font size="14.0"/></font></Label>
                <TextArea fx:id="txtAddress" prefHeight="120.0" prefWidth="550.0" promptText="Nhập chuỗi địa chỉ dài đầy đủ (Số nhà, Tên đường, Phường, Quận, Thành phố)..." wrapText="true" style="-fx-font-size: 14px;" />
            </children>
        </VBox>
        <HBox spacing="15.0">
            <children>
                <Button onAction="#onUpdateAddress" prefHeight="38.0" prefWidth="120.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Cập nhật" />
                <Button onAction="#onDeleteAddress" prefHeight="38.0" prefWidth="120.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Xóa" />
            </children>
        </HBox>
    </children>
</VBox>