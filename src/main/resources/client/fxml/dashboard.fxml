<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #2c3e50; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);" BorderPane.alignment="CENTER">
            <children>
                <Label onMouseClicked="#onHomeButtonClicked" style="-fx-cursor: hand;" text="AUCTION SYSTEM" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                    <HBox.margin>
                        <Insets left="25.0" />
                    </HBox.margin>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#onSellerChannelButtonClicked" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="🏪 Kênh Người Bán">
                    <padding>
                        <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
                    </padding>
                    <HBox.margin>
                        <Insets right="20.0" />
                    </HBox.margin>
                </Button>

                <Label fx:id="lblWelcome" text="Xin chào, Guest" textFill="WHITE">
                    <font>
                        <Font size="15.0" />
                    </font>
                    <HBox.margin>
                        <Insets right="20.0" />
                    </HBox.margin>
                </Label>

                <Button mnemonicParsing="false" onAction="#onLogoutButtonClicked" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Đăng xuất">
                    <padding>
                        <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
                    </padding>
                    <HBox.margin>
                        <Insets right="25.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebar" prefWidth="220.0" spacing="10.0" style="-fx-background-color: #34495e;" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnHome" maxWidth="Infinity" mnemonicParsing="false" onAction="#onHomeButtonClicked" prefHeight="50.0" text="⌂ Trang chủ">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Button fx:id="btnProductList" maxWidth="Infinity" mnemonicParsing="false" onAction="#onProductListButtonClicked" prefHeight="50.0" text="📦 Danh sách sản phẩm">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Button maxWidth="Infinity" mnemonicParsing="false" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="🔨 Đơn mua">
                    <font>
                        <Font size="14.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Button fx:id="btnWallet" maxWidth="Infinity" mnemonicParsing="false" onAction="#onWalletButtonClicked" prefHeight="50.0" text="👤 Ví tiền">
                    <font>
                        <Font size="14.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onOpenSettings" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;" text="⚙ Cài đặt">
                    <font>
                        <Font size="14.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>
            </children>
            <padding>
                <Insets bottom="20.0" top="20.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <StackPane style="-fx-background-color: #f4f7f6;" BorderPane.alignment="CENTER">
            <children>
                <VBox fx:id="homeView" spacing="24.0">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <VBox spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 28;">
                            <children>
                                <Label fx:id="lblHomeTitle" text="Chào mừng đến Auction System" textFill="#2c3e50">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                                <Label text="Theo dõi phiên đấu giá, sản phẩm yêu thích và kênh người bán từ một nơi." textFill="#6b7c85" wrapText="true">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                                <HBox spacing="12.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#onProductListButtonClicked" style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Xem danh sách sản phẩm">
                                            <padding>
                                                <Insets bottom="10.0" left="18.0" right="18.0" top="10.0" />
                                            </padding>
                                        </Button>
                                        <Button mnemonicParsing="false" onAction="#onSellerChannelButtonClicked" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Kênh Người Bán">
                                            <padding>
                                                <Insets bottom="10.0" left="18.0" right="18.0" top="10.0" />
                                            </padding>
                                        </Button>
                                    </children>
                                    <VBox.margin>
                                        <Insets top="14.0" />
                                    </VBox.margin>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox spacing="18.0">
                            <children>
                                <VBox HBox.hgrow="ALWAYS" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 20;">
                                    <children>
                                        <Label text="Phiên đấu giá" textFill="#7f8c8d" />
                                        <Label text="0" textFill="#2c3e50">
                                            <font>
                                                <Font name="System Bold" size="30.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 20;">
                                    <children>
                                        <Label text="Sản phẩm" textFill="#7f8c8d" />
                                        <Label text="0" textFill="#2c3e50">
                                            <font>
                                                <Font name="System Bold" size="30.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 20;">
                                    <children>
                                        <Label text="Thông báo" textFill="#7f8c8d" />
                                        <Label text="0" textFill="#2c3e50">
                                            <font>
                                                <Font name="System Bold" size="30.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox fx:id="productListView" managed="false" spacing="20.0" visible="false">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Sàn Đấu Giá Trực Tuyến">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" text="🔄 Làm mới">
                                    <padding>
                                        <Insets bottom="7.0" left="15.0" right="15.0" top="7.0" />
                                    </padding>
                                </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="tableItems" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" maxWidth="60.0" minWidth="40.0" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colName" prefWidth="250.0" text="Tên sản phẩm" />
                                <TableColumn fx:id="colCurrentPrice" prefWidth="130.0" text="Giá hiện tại" />
                                <TableColumn fx:id="colEndTime" prefWidth="180.0" text="Thời gian kết thúc" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox fx:id="walletView" managed="false" spacing="18.0" visible="false">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Ví tiền">
                                            <font>
                                                <Font name="System Bold" size="24.0" />
                                            </font>
                                        </Label>
                                        <Label text="Quản lý số dư, nạp rút tiền và lịch sử giao dịch." textFill="#6b7c85" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <VBox alignment="CENTER_RIGHT" spacing="4.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 16;">
                                    <children>
                                        <Label text="Số dư hiện có" textFill="#7f8c8d" />
                                        <Label fx:id="lblWalletBalance" text="0 ₫" textFill="#1abc9c">
                                            <font>
                                                <Font name="System Bold" size="26.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="12.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-border-color: #e6ecf0; -fx-border-radius: 8; -fx-padding: 20;">
                            <children>
                                <HBox spacing="12.0">
                                    <children>
                                        <TextField fx:id="txtWalletAmount" prefWidth="220.0" promptText="Số tiền" />
                                        <TextField fx:id="txtWalletNote" HBox.hgrow="ALWAYS" promptText="Ghi chú" />
                                        <Button mnemonicParsing="false" onAction="#onDepositButtonClicked" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Nạp tiền">
                                            <padding>
                                                <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
                                            </padding>
                                        </Button>
                                        <Button mnemonicParsing="false" onAction="#onWithdrawButtonClicked" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Rút tiền">
                                            <padding>
                                                <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
                                            </padding>
                                        </Button>
                                    </children>
                                </HBox>

                                <HBox fx:id="walletBankErrorBox" alignment="CENTER_LEFT" managed="false" spacing="8.0" visible="false">
                                    <children>
                                        <Label fx:id="lblWalletError" textFill="#e74c3c" />
                                        <Button mnemonicParsing="false" onAction="#onOpenBankSettings" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;" text="Thiết lập ngân hàng" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <TableView fx:id="tableWalletHistory" prefHeight="260.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colWalletTime" prefWidth="190.0" text="Thời gian" />
                                <TableColumn fx:id="colWalletAmount" prefWidth="150.0" text="Số tiền" />
                                <TableColumn fx:id="colWalletType" prefWidth="120.0" text="Phân loại" />
                                <TableColumn fx:id="colWalletNote" prefWidth="260.0" text="Ghi chú" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
