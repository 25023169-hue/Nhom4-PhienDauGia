<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.AdminDashboardController">
    <children>
        <!-- Sidebar -->
        <VBox prefWidth="220.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <children>
                <Label text="ADMIN SYSTEM" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0" /></font>
                </Label>
                <Separator prefWidth="200.0" style="-fx-padding: 15 0;" />
                <Button maxWidth="Infinity" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Quản lý Người dùng" />
                <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Thống kê Đấu giá" />
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="Infinity" onAction="#onLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Đăng xuất" />
            </children>
        </VBox>

        <!-- Content Area -->
        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS">
            <content>
                <VBox spacing="20.0" style="-fx-padding: 25; -fx-background-color: #f4f7f6;">
                    <children>
                        <Label text="Bảng điều khiển hệ thống">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>

                        <!-- Biểu đồ thống kê (Ví dụ biểu đồ cột) -->
                        <BarChart fx:id="auctionChart" prefHeight="250.0" title="Thống kê phiên đấu giá theo tháng">
                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </BarChart>

                        <!-- Bảng quản lý người dùng -->
                        <Label text="Danh sách tài khoản">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <TableView fx:id="userTable" prefHeight="300.0">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="colUsername" prefWidth="140.0" text="Tên đăng nhập" />
                                <TableColumn fx:id="colFullName" prefWidth="180.0" text="Họ tên" />
                                <TableColumn fx:id="colRole" prefWidth="100.0" text="Vai trò" />
                                <TableColumn fx:id="colAction" prefWidth="150.0" text="Thao tác" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</HBox>