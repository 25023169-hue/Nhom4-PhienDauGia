<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1150.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.auctionsystem.client.controller.SellerDashboardController">

    <!-- CỘT BÊN TRÁI (SIDEBAR) -->
    <left>
        <VBox prefWidth="280.0" spacing="15.0" style="-fx-background-color: #1a2235; -fx-background-radius: 0 20 20 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="25.0" right="25.0" top="40.0" />
            </padding>
            <children>

                      <!-- Khu vực Profile -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Label alignment="CENTER" minHeight="54.0" minWidth="54.0" style="-fx-background-color: #fbd38d; -fx-background-radius: 27;" text="👨" textFill="#333333">
                            <font>
                        <Font size="26.0" />
                     </font>
                        </Label>
                        <VBox alignment="CENTER_LEFT" spacing="2.0">
                            <children>
                                <Label textFill="WHITE">
                                    <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                                </Label>
                                <Label text="Chủ Kênh" textFill="#94a3b8">
                                    <font>
                              <Font size="13.0" />
                           </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                    <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
                </HBox>

                      <!-- Tiêu đề Kênh -->
                <Label alignment="TOP_LEFT" text="KÊNH NGƯỜI BÁN 🔨" textFill="WHITE" wrapText="true">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>

                      <!-- Các nút Menu -->
                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="50.0" prefWidth="230.0" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 8; -fx-border-color: #10b981; -fx-border-width: 0 0 0 4; -fx-border-radius: 8;" text="📦  Sản phẩm của tôi">
                    <font>
                  <Font name="System Bold" size="14.0" />
               </font>
                    <padding>
                  <Insets left="15.0" />
               </padding>
                </Button>

                      <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="50.0" prefWidth="230.0" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand;" text="🛒  Quản lý Đơn hàng">
                    <font>
                  <Font size="14.0" />
               </font>
                    <padding>
                  <Insets left="15.0" />
               </padding>
                </Button>

                      <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="50.0" prefWidth="230.0" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand;" text="📊  Thống kê doanh thu">
                    <font>
                  <Font size="14.0" />
               </font>
                    <padding>
                  <Insets left="15.0" />
               </padding>
                </Button>

                      <Region VBox.vgrow="ALWAYS" />

                      <!-- Nút Trở về -->
                <Button mnemonicParsing="false" onAction="#onBackToBuyerChannelClicked" prefHeight="45.0" prefWidth="230.0" style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-border-radius: 10; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-cursor: hand;" text="←  Trở về Kênh Người Mua">
                    <font>
                  <Font size="13.0" />
               </font>
                </Button>
            </children>

                  <effect>
                <DropShadow height="30.0" radius="14.5" width="30.0">
                    <color>
                  <Color opacity="0.15" />
               </color>
                </DropShadow>
            </effect>
        </VBox>
    </left>

    <!-- KHU VỰC TRUNG TÂM (MAIN CONTENT) -->
    <center>
        <VBox spacing="25.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>

                <!-- Tiêu đề trang -->
                <HBox alignment="BASELINE_LEFT" spacing="10.0">
                    <children>
                        <Label text="Sản phẩm của tôi 🎁" textFill="#1e293b">
                            <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                        <Label text="(99 items)" textFill="#64748b">
                            <font><Font size="14.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <!-- Thanh Công Cụ (Toolbar) -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="42.0" prefWidth="320.0" promptText="🔍 Nhập tên hoặc ID sản phẩm..." style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;">
                            <font><Font size="14.0" /></font>
                        </TextField>

                        <ComboBox fx:id="cbStatusFilter" prefHeight="42.0" prefWidth="180.0" promptText="Tất cả trạng thái" style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Button mnemonicParsing="false" onAction="#onAddProductClicked" prefHeight="42.0" prefWidth="160.0" style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 8;" text="Add Product +">
                            <font><Font size="14.0" /></font>
                            <effect>
                                <DropShadow offsetY="4.0" radius="10.0" width="20.0">
                                    <color><Color green="0.72" blue="0.5" opacity="0.4" /></color>
                                </DropShadow>
                            </effect>
                        </Button>
                    </children>
                </HBox>

                <!-- Bảng Dữ Liệu (TableView) -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12;" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                    <children>
                        <TableView fx:id="tableMyProducts" prefHeight="200.0" prefWidth="200.0" style="-fx-base: white; -fx-control-inner-background: white; -fx-background-color: transparent; -fx-table-header-border-color: transparent; -fx-font-size: 14px;" VBox.vgrow="ALWAYS">
                            <columns>
                                <!-- Gộp ID và Tên vào 1 cột cho đẹp giống UI -->
                                <TableColumn fx:id="colName" minWidth="250.0" prefWidth="350.0" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 10;" text="Tên Sản Phẩm" />
                                <TableColumn fx:id="colPrice" minWidth="120.0" prefWidth="180.0" style="-fx-alignment: CENTER-LEFT;" text="Giá Khởi Điểm" />
                                <TableColumn fx:id="colStatus" minWidth="120.0" prefWidth="180.0" style="-fx-alignment: CENTER;" text="Trạng Thái" />
                                <TableColumn fx:id="colAction" minWidth="150.0" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Hành Động" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <effect>
                        <DropShadow offsetY="5.0" radius="10.0" width="20.0">
                            <color><Color opacity="0.05" /></color>
                        </DropShadow>
                    </effect>
                </VBox>

            </children>
        </VBox>
    </center>
</BorderPane>
